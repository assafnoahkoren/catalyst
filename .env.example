# ──────────────────────────────────────────────
# Local Dev (works out of the box with docker compose up)
# ──────────────────────────────────────────────
DATABASE_URL="mongodb://localhost:27018/catalyst?replicaSet=rs0&directConnection=true"
BETTER_AUTH_SECRET="change-me-to-a-random-secret"
BETTER_AUTH_URL="http://localhost:3001"
LOG_TRANSPORT="stdout"
LOG_LEVEL="debug"
VITE_API_URL="http://localhost:3001"
CORS_ORIGIN="http://localhost:5173"

# ──────────────────────────────────────────────
# CRM Services
# ──────────────────────────────────────────────
OPENAI_API_KEY=""
QDRANT_URL="http://localhost:6333"
GREEN_API_INSTANCE=""
GREEN_API_TOKEN=""

# ──────────────────────────────────────────────
# Render (deployment)
# Get your API key at: https://dashboard.render.com/settings#api-keys
# ──────────────────────────────────────────────
RENDER_API_KEY=""

# ──────────────────────────────────────────────
# Axiom (observability / logs)
# Sign up at: https://axiom.co
# Create two datasets: catalyst-dev, catalyst-prod
# Get your API token at: https://app.axiom.co/settings/api-tokens
# ──────────────────────────────────────────────
AXIOM_TOKEN=""
AXIOM_DATASET="catalyst-dev"

# ──────────────────────────────────────────────
# GitHub (CI/CD — stored as repo secrets, not here)
# These are listed for reference only:
#   GITHUB_TOKEN      — auto-provided by GitHub Actions
#   RENDER_API_KEY    — add as repo secret
#   RENDER_SERVER_DEV_ID  — Render service ID for dev
#   RENDER_SERVER_PROD_ID — Render service ID for prod
# ──────────────────────────────────────────────
