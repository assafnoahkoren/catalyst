{
  "name": "@catalyst/db",
  "private": true,
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "tsc --noEmit",
    "lint": "oxlint -c ../lint-config/oxlint.json src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "seed": "bun run --env-file ../../.env src/seed.ts",
    "db:push": "bunx prisma db push",
    "db:generate": "bunx prisma generate"
  },
  "devDependencies": {
    "@catalyst/tsconfig": "workspace:*",
    "prisma": "6",
    "typescript": "^5"
  },
  "dependencies": {
    "@prisma/client": "6"
  }
}
