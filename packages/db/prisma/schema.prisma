generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sessions      Session[]
  accounts      Account[]
  tenantMembers TenantMember[]
}

model Session {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?

  userId String @db.ObjectId
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                String  @id @default(auto()) @map("_id") @db.ObjectId
  accountId         String
  providerId        String
  userId            String  @db.ObjectId
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken       String?
  refreshToken      String?
  idToken           String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope             String?
  password          String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

enum TenantRole {
  OWNER
  ADMIN
  MEMBER
}

model Tenant {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  name             String
  slug             String   @unique
  plan             String   @default("free")
  language         String   @default("en")
  settings         Json     @default("{}")
  greenApiInstance String?
  greenApiToken    String?
  createdAt        DateTime @default(now())

  members          TenantMember[]
  customerStatuses CustomerStatus[]
  customers        Customer[]
  customFields     CustomFieldDefinition[]
  conversations    Conversation[]
  notes            Note[]
  activities       Activity[]
  automationFlows  AutomationFlow[]
  webhookEndpoints WebhookEndpoint[]
}

model TenantMember {
  id        String     @id @default(auto()) @map("_id") @db.ObjectId
  role      TenantRole @default(MEMBER)
  invitedAt DateTime   @default(now())
  joinedAt  DateTime?

  userId   String @db.ObjectId
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenantId String @db.ObjectId
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([userId, tenantId])
}

enum CustomerSource {
  WEBHOOK
  MANUAL
  FACEBOOK
  IMPORT
}

enum CustomFieldType {
  TEXT
  NUMBER
  DATE
  SELECT
  MULTI_SELECT
  BOOLEAN
  URL
  PHONE
}

model CustomerStatus {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  color       String   @default("#6B7280")
  order       Int
  isDefault   Boolean  @default(false)
  isClosed    Boolean  @default(false)
  autoMessage String?
  createdAt   DateTime @default(now())

  tenantId  String     @db.ObjectId
  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customers Customer[]
}

model Customer {
  id           String         @id @default(auto()) @map("_id") @db.ObjectId
  name         String
  email        String?
  phone        String?
  source       CustomerSource @default(MANUAL)
  customFields Json           @default("{}")
  tags         String[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  tenantId     String         @db.ObjectId
  tenant       Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  statusId     String         @db.ObjectId
  status       CustomerStatus @relation(fields: [statusId], references: [id])
  assignedToId String?        @db.ObjectId

  conversations Conversation[]
  notes         Note[]
  activities    Activity[]
}

model CustomFieldDefinition {
  id         String          @id @default(auto()) @map("_id") @db.ObjectId
  name       String
  key        String
  type       CustomFieldType @default(TEXT)
  options    String[]
  isRequired Boolean         @default(false)
  order      Int             @default(0)
  createdAt  DateTime        @default(now())

  tenantId String @db.ObjectId
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, key])
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum MessageSender {
  BOT
  HUMAN
  CUSTOMER
}

enum ActivityType {
  STATUS_CHANGE
  MESSAGE
  NOTE
  ASSIGNMENT
  CREATED
  CUSTOM_FIELD_CHANGE
}

model Conversation {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  channel   String   @default("WHATSAPP")
  isBot     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenantId     String    @db.ObjectId
  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customerId   String    @db.ObjectId
  customer     Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  assignedToId String?   @db.ObjectId
  messages     Message[]
}

model Message {
  id        String           @id @default(auto()) @map("_id") @db.ObjectId
  direction MessageDirection
  sender    MessageSender
  body      String
  mediaUrl  String?
  sentAt    DateTime         @default(now())

  conversationId String       @db.ObjectId
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

model Note {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenantId   String   @db.ObjectId
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customerId String   @db.ObjectId
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  authorId   String   @db.ObjectId
}

model Activity {
  id        String       @id @default(auto()) @map("_id") @db.ObjectId
  type      ActivityType
  data      Json         @default("{}")
  createdAt DateTime     @default(now())

  tenantId   String   @db.ObjectId
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customerId String   @db.ObjectId
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  actorId    String?  @db.ObjectId
}

enum AutomationLogStatus {
  SUCCESS
  FAILED
  PENDING
}

enum ScheduledTaskStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

model AutomationFlow {
  id       String  @id @default(auto()) @map("_id") @db.ObjectId
  name     String
  isActive Boolean @default(false)
  trigger  Json
  steps    Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenantId       String            @db.ObjectId
  tenant         Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  automationLogs AutomationLog[]
  scheduledTasks ScheduledTask[]
}

model AutomationLog {
  id         String              @id @default(auto()) @map("_id") @db.ObjectId
  stepIndex  Int
  status     AutomationLogStatus
  result     Json                @default("{}")
  executedAt DateTime            @default(now())

  flowId     String         @db.ObjectId
  flow       AutomationFlow @relation(fields: [flowId], references: [id], onDelete: Cascade)
  customerId String         @db.ObjectId
}

model WebhookEndpoint {
  id           String  @id @default(auto()) @map("_id") @db.ObjectId
  token        String  @unique
  fieldMapping Json    @default("{}")
  isActive     Boolean @default(true)
  createdAt    DateTime @default(now())

  tenantId String @db.ObjectId
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model ScheduledTask {
  id        String              @id @default(auto()) @map("_id") @db.ObjectId
  stepIndex Int
  executeAt DateTime
  status    ScheduledTaskStatus @default(PENDING)
  createdAt DateTime            @default(now())

  flowId     String         @db.ObjectId
  flow       AutomationFlow @relation(fields: [flowId], references: [id], onDelete: Cascade)
  customerId String         @db.ObjectId
}

model Verification {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}
