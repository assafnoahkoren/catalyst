{
  "name": "catalyst",
  "private": true,
  "packageManager": "bun@1.2.21",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "format": "turbo run format",
    "format:check": "turbo run format:check",
    "typecheck": "turbo run typecheck",
    "prepare": "husky"
  },
  "devDependencies": {
    "bun-types": "^1.3.12",
    "dprint": "^0.54.0",
    "husky": "^9",
    "lint-staged": "^15",
    "oxlint": "^1.60.0",
    "turbo": "^2"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "oxlint",
      "dprint check"
    ],
    "*.{json,md}": [
      "dprint check"
    ]
  }
}
